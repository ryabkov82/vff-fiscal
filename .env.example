# SHM -> vff-fiscal authentication. Generate with: openssl rand -hex 32
VFF_FISCAL_API_KEY=replace-me

# Persistent state containing the rotated refresh token and receipt registry.
VFF_FISCAL_STATE_PATH=/var/lib/vff-fiscal/state.json

# Initial credentials. After the first successful refresh, the service persists
# a rotated refresh token to the state file.
LKNPD_INN=000000000000
LKNPD_REFRESH_TOKEN=replace-me
LKNPD_DEVICE_ID=replace-me

LKNPD_BASE_URL=https://lknpd.nalog.ru/api/v1
LKNPD_TIMEZONE_OFFSET=+03:00
LKNPD_PAYMENT_TYPE=WIRE
LKNPD_HTTP_TIMEOUT_SECONDS=30
VFF_FISCAL_SERVICE_NAME=Услуга доступа к VPN-сервису VPN for Friends
